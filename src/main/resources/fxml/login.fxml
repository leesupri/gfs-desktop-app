<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.gfs.app.ui.LoginController"
           styleClass="login-root">

    <!-- Main card - contains both columns -->
    <HBox spacing="0" styleClass="login-card" maxWidth="850" maxHeight="-Infinity" HBox.hgrow="NEVER">
        <padding><Insets top="0" right="0" bottom="0" left="0"/></padding>

        <!-- Left column: Logo / mascot panel -->
        <VBox fx:id="mascotPanel" spacing="16" alignment="CENTER" styleClass="mascot-panel-left"
              HBox.hgrow="ALWAYS" maxWidth="350">
            <padding><Insets top="40" right="24" bottom="40" left="24"/></padding>
            <StackPane styleClass="mascot-circle">
                <ImageView fitWidth="140" preserveRatio="true" smooth="true">
                    <Image url="@/images/Logo_GUNDALING_2-color_tall_on-white.png" backgroundLoading="true"/>
                </ImageView>
            </StackPane>
            <Label text="Gundaling Farmstead" styleClass="mascot-title" wrapText="true" textAlignment="CENTER"/>
            <Label text="Fresh farm identity for internal PC software — friendly, clean, and easy for staff to understand."
                   styleClass="mascot-text" wrapText="true" textAlignment="CENTER"/>
            <HBox spacing="8" alignment="CENTER">
                <Label text="POS Ready" styleClass="badge"/>
                <Label text="Staff Login" styleClass="badge"/>
                <Label text="Admin Panel" styleClass="badge"/>
            </HBox>
        </VBox>

        <!-- Right column: Login form -->
        <VBox spacing="16" styleClass="login-form-panel" HBox.hgrow="ALWAYS" maxWidth="500">
            <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>
            <VBox spacing="6">
                <Label text="Gundaling Staff System" styleClass="login-badge"/>
                <Label text="Welcome Back" styleClass="login-title"/>
                <Label text="Login to access Gundaling Farmstead PC software dashboard."
                       styleClass="login-subtitle" wrapText="true"/>
            </VBox>

            <VBox spacing="12">
                <VBox spacing="4">
                    <Label text="Username" styleClass="form-label"/>
                    <TextField fx:id="usernameField" promptText="Enter username" styleClass="login-field"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Password" styleClass="form-label"/>
                    <HBox alignment="CENTER_LEFT" spacing="8" styleClass="login-field">
                        <PasswordField fx:id="passwordField" promptText="Enter password" HBox.hgrow="ALWAYS"/>
                        <Button fx:id="showPasswordButton" text="👁" styleClass="toggle-password-btn"
                                onAction="#togglePasswordVisibility"/>
                    </HBox>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="15">
                    <CheckBox fx:id="rememberCheckbox" text="Remember this PC" styleClass="checkbox"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="forgotPasswordButton" text="Forgot password?" styleClass="link-button"
                            onAction="#handleForgotPassword"/>
                </HBox>

                <Button text="Login" onAction="#handleLogin" styleClass="login-button"/>

                <Label fx:id="messageLabel" styleClass="login-message"/>
            </VBox>

            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="🔒" style="-fx-font-size: 14px;"/>
                <Label text="Secure access for admin, cashier, kitchen, and manager users."
                       styleClass="secure-text" wrapText="true"/>
            </HBox>
        </VBox>
    </HBox>
</StackPane>

