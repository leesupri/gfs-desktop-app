<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gfs.app.ui.ProductionSummaryController"
      styleClass="content-pane" spacing="14">
    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label text="Production Summary" styleClass="content-title"/>
            <Label text="Grouped by category. Click a production record on the right to view its full detail."
                   styleClass="content-subtitle"/>
        </VBox>
        <Button text="Export CSV" onAction="#handleExport"  styleClass="secondary-button"/>
        <Button text="Refresh"    onAction="#handleRefresh" styleClass="secondary-button"/>
        <Button text="Search"     onAction="#handleSearch"  styleClass="primary-button"/>
    </HBox>

    <!-- Filters card -->
    <VBox styleClass="filter-card" spacing="10">
        <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
        <Label text="Filters" styleClass="section-title"/>
        <HBox spacing="12">
            <VBox spacing="5">
                <Label text="Start Date" styleClass="form-label"/>
                <DatePicker fx:id="startDatePicker" prefWidth="135"/>
            </VBox>
            <VBox spacing="5">
                <Label text="End Date" styleClass="form-label"/>
                <DatePicker fx:id="endDatePicker" prefWidth="135"/>
            </VBox>
            <VBox spacing="5" prefWidth="160">
                <Label text="Category" styleClass="form-label"/>
                <ComboBox fx:id="categoryFilter" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="5" prefWidth="160">
                <Label text="Warehouse" styleClass="form-label"/>
                <ComboBox fx:id="warehouseFilter" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Item" styleClass="form-label"/>
                <TextField fx:id="itemField" promptText="Search item name"/>
            </VBox>
        </HBox>
        <HBox alignment="CENTER_RIGHT">
            <Label fx:id="resultLabel" text="0 item(s)" styleClass="result-label"/>
        </HBox>
    </VBox>

    <!-- Main split: summary tree (left) + production list (right) -->
    <HBox spacing="14" VBox.vgrow="ALWAYS">

        <!-- Summary tree -->
        <StackPane HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
            <TreeTableView fx:id="treeTable" showRoot="false" styleClass="staff-table">
                <columns>
                    <TreeTableColumn fx:id="colCategory"  text="Category"   prefWidth="140" minWidth="100"/>
                    <TreeTableColumn fx:id="colItemName"  text="Item Name"   prefWidth="220" minWidth="150"/>
                    <TreeTableColumn fx:id="colItemCode"  text="Item Code"   prefWidth="100" minWidth="80"/>
                    <TreeTableColumn fx:id="colQuantity"  text="Quantity"    prefWidth="100" minWidth="80"/>
                    <TreeTableColumn fx:id="colUom"       text="UOM"         prefWidth="80"  minWidth="60"/>
                    <TreeTableColumn fx:id="colWarehouse" text="Warehouse"   prefWidth="130" minWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="No production data. Adjust the date range."
                           styleClass="content-subtitle"/>
                </placeholder>
            </TreeTableView>

            <StackPane fx:id="loadingOverlay" visible="false"
                       style="-fx-background-color: rgba(0,0,0,0.35);">
                <ProgressIndicator fx:id="progressIndicator"/>
            </StackPane>
        </StackPane>

        <!-- Production ID list -->
        <VBox styleClass="staff-card" prefWidth="250" minWidth="220" spacing="0">
            <HBox styleClass="staff-card-header" alignment="CENTER_LEFT">
                <Label fx:id="productionListLabel" text="Production Records"
                       styleClass="card-section-label" HBox.hgrow="ALWAYS"/>
            </HBox>
            <ListView fx:id="productionList" VBox.vgrow="ALWAYS"
                      styleClass="role-list-view">
                <placeholder>
                    <VBox alignment="CENTER" spacing="6" style="-fx-padding:20;">
                        <Label text="No production records" styleClass="content-subtitle"/>
                        <Label text="in this date range."  styleClass="content-subtitle"/>
                    </VBox>
                </placeholder>
            </ListView>
        </VBox>

    </HBox>
</VBox>
