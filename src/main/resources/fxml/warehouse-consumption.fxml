<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gfs.app.ui.WarehouseConsumptionController"
      spacing="14" styleClass="content-pane">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Title -->
    <VBox spacing="4">
        <Label text="Warehouse Consumption Report" styleClass="content-title"/>
        <Label text="Filter by date range, warehouse, or item. Grouped by warehouse."
               styleClass="content-subtitle"/>
    </VBox>

    <!-- Filters card -->
    <VBox spacing="12" styleClass="filter-card">
        <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>

        <Label text="Filters" styleClass="section-title"/>

        <!-- Row 1: dates + warehouse + item -->
        <HBox spacing="12">
            <VBox spacing="6">
                <Label text="Start Date" styleClass="form-label"/>
                <DatePicker fx:id="startDatePicker" prefWidth="140"/>
            </VBox>
            <VBox spacing="6">
                <Label text="End Date" styleClass="form-label"/>
                <DatePicker fx:id="endDatePicker" prefWidth="140"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Warehouse" styleClass="form-label"/>
                <TextField fx:id="warehouseField" promptText="Leave empty for all"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Item" styleClass="form-label"/>
                <TextField fx:id="itemField" promptText="Leave empty for all"/>
            </VBox>
        </HBox>

        <!-- Row 2: actions + summary labels -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button text="Search"     onAction="#handleSearch"  styleClass="primary-button"/>
            <Button text="Refresh"    onAction="#handleRefresh" styleClass="secondary-button"/>
            <Button text="Export CSV" onAction="#handleExport"  styleClass="secondary-button"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="resultLabel" text="0 item(s)"       styleClass="result-label"/>
            <Label fx:id="totalLabel"  text="Total Cost: --"   styleClass="result-label"/>
        </HBox>
    </VBox>

    <!-- TreeTableView with loading overlay -->
    <StackPane VBox.vgrow="ALWAYS">
        <TreeTableView fx:id="treeTableView" showRoot="false" styleClass="report-table">
            <columns>
                <TreeTableColumn fx:id="warehouseColumn" text="Warehouse" prefWidth="180"/>
                <TreeTableColumn fx:id="itemColumn"      text="Item"      prefWidth="280"/>
                <TreeTableColumn fx:id="uomColumn"       text="UOM"       prefWidth="100"/>
                <TreeTableColumn fx:id="quantityColumn"  text="Quantity"  prefWidth="120"/>
                <TreeTableColumn fx:id="totalCostColumn" text="Total Cost" prefWidth="150"/>
            </columns>
        </TreeTableView>

        <StackPane fx:id="loadingOverlay" visible="false"
                   style="-fx-background-color: rgba(0,0,0,0.35);">
            <ProgressIndicator fx:id="progressIndicator"/>
        </StackPane>
    </StackPane>
</VBox>
