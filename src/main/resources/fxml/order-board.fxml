<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gfs.app.ui.OrderBoardController"
      styleClass="content-pane" spacing="14">
    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label text="Order Board" styleClass="content-title"/>
            <Label text="All order lines grouped by bill. Click a row to expand and see individual items."
                   styleClass="content-subtitle"/>
        </VBox>
        <Button text="Export CSV" onAction="#handleExport"  styleClass="secondary-button"/>
        <Button text="Refresh"    onAction="#handleRefresh" styleClass="secondary-button"/>
        <Button text="Search"     onAction="#handleSearch"  styleClass="primary-button"/>
    </HBox>

    <!-- Filters card -->
    <VBox styleClass="filter-card" spacing="10">
        <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
        <Label text="Filters" styleClass="section-title"/>

        <!-- Row 1: dates + invoice + table + keyword -->
        <HBox spacing="10">
            <VBox spacing="5">
                <Label text="Start Date" styleClass="form-label"/>
                <DatePicker fx:id="startDatePicker" prefWidth="130"/>
            </VBox>
            <VBox spacing="5">
                <Label text="End Date" styleClass="form-label"/>
                <DatePicker fx:id="endDatePicker" prefWidth="130"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Invoice ID" styleClass="form-label"/>
                <TextField fx:id="invoiceField" promptText="Search invoice"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Table" styleClass="form-label"/>
                <TextField fx:id="tableField" promptText="Table name"/>
            </VBox>
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Keyword" styleClass="form-label"/>
                <TextField fx:id="keywordField" promptText="Item / employee / customer"/>
            </VBox>
        </HBox>

        <!-- Row 2: dropdowns -->
        <HBox spacing="10">
            <VBox spacing="5" prefWidth="180">
                <Label text="Station" styleClass="form-label"/>
                <ComboBox fx:id="stationFilter" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="5" prefWidth="180">
                <Label text="Department" styleClass="form-label"/>
                <ComboBox fx:id="departmentFilter" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="5" prefWidth="180">
                <Label text="Category" styleClass="form-label"/>
                <ComboBox fx:id="categoryFilter" maxWidth="Infinity"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- Summary totals -->
        <HBox spacing="24" alignment="CENTER_RIGHT">
            <Label fx:id="resultLabel" text="0 bill(s)" styleClass="result-label"/>
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="Gross:" styleClass="form-label"/>
                <Label fx:id="grossLabel" text="--" styleClass="result-label"/>
            </HBox>
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="Discount:" styleClass="form-label"/>
                <Label fx:id="discountLabel" text="--" styleClass="result-label"/>
            </HBox>
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="Net:" styleClass="form-label"/>
                <Label fx:id="netLabel" text="--"
                       style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#3a2316;"/>
            </HBox>
        </HBox>
    </VBox>

    <!-- Tree table -->
    <StackPane VBox.vgrow="ALWAYS">
        <TreeTableView fx:id="treeTable" showRoot="false" styleClass="staff-table">
            <columns>
                <TreeTableColumn fx:id="colInvoice"  text="Invoice"       prefWidth="90"  minWidth="70"/>
                <TreeTableColumn fx:id="colDate"     text="Date / Time"   prefWidth="130" minWidth="110"/>
                <TreeTableColumn fx:id="colType"     text="Type"          prefWidth="70"  minWidth="60"/>
                <TreeTableColumn fx:id="colTable"    text="Table"         prefWidth="80"  minWidth="60"/>
                <TreeTableColumn fx:id="colStation"  text="Station"       prefWidth="140" minWidth="100"/>
                <TreeTableColumn fx:id="colDept"     text="Dept / Cat"    prefWidth="140" minWidth="100"/>
                <TreeTableColumn fx:id="colItem"     text="Item"          prefWidth="200" minWidth="140"/>
                <TreeTableColumn fx:id="colQty"      text="Qty"           prefWidth="55"  minWidth="45"/>
                <TreeTableColumn fx:id="colPrice"    text="Gross"         prefWidth="100" minWidth="80"/>
                <TreeTableColumn fx:id="colDiscount" text="Discount"      prefWidth="90"  minWidth="70"/>
                <TreeTableColumn fx:id="colNet"      text="Net"           prefWidth="100" minWidth="80"/>
                <TreeTableColumn fx:id="colEmployee" text="Ordered By"    prefWidth="110" minWidth="80"/>
                <TreeTableColumn fx:id="colClosedBy" text="Closed By"     prefWidth="110" minWidth="80"/>
            </columns>
            <placeholder>
                <Label text="No orders found. Adjust the date range and filters."
                       styleClass="content-subtitle"/>
            </placeholder>
        </TreeTableView>

        <StackPane fx:id="loadingOverlay" visible="false"
                   style="-fx-background-color: rgba(0,0,0,0.35);">
            <ProgressIndicator fx:id="progressIndicator"/>
        </StackPane>
    </StackPane>
</VBox>
