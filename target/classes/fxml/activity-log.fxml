<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gfs.app.ui.ActivityLogController"
      styleClass="content-pane" spacing="16">
    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label text="Activity Log" styleClass="content-title"/>
            <Label text="Audit trail of all user actions. Most recent first."
                   styleClass="content-subtitle"/>
        </VBox>
        <Button text="Export CSV" onAction="#handleExport" styleClass="secondary-button"/>
        <Button text="Refresh"    onAction="#handleRefresh" styleClass="secondary-button"/>
        <Button text="Search"     onAction="#handleSearch"  styleClass="primary-button"/>
    </HBox>

    <!-- Filters card -->
    <VBox styleClass="filter-card" spacing="12">
        <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>

        <Label text="Filters" styleClass="section-title"/>

        <HBox spacing="12">
            <VBox spacing="6">
                <Label text="Start Date" styleClass="form-label"/>
                <DatePicker fx:id="startDatePicker" prefWidth="140"/>
            </VBox>
            <VBox spacing="6">
                <Label text="End Date" styleClass="form-label"/>
                <DatePicker fx:id="endDatePicker" prefWidth="140"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Username" styleClass="form-label"/>
                <TextField fx:id="usernameField" promptText="Filter by username"/>
            </VBox>
            <VBox spacing="6" prefWidth="180">
                <Label text="Action" styleClass="form-label"/>
                <ComboBox fx:id="actionFilter" maxWidth="Infinity"/>
            </VBox>
        </HBox>

        <HBox alignment="CENTER_RIGHT">
            <Label fx:id="resultLabel" text="0 record(s)" styleClass="result-label"/>
        </HBox>
    </VBox>

    <!-- Table with loading overlay -->
    <StackPane VBox.vgrow="ALWAYS">
        <TableView fx:id="tableView" styleClass="staff-table">
            <columns>
                <TableColumn fx:id="colTimestamp"   text="Timestamp"   prefWidth="160" minWidth="140"/>
                <TableColumn fx:id="colUsername"     text="Username"    prefWidth="130" minWidth="100"/>
                <TableColumn fx:id="colAction"       text="Action"      prefWidth="160" minWidth="120"/>
                <TableColumn fx:id="colDescription"  text="Description" prefWidth="400" minWidth="200"/>
            </columns>
            <placeholder>
                <Label text="No activity records found for the selected filters."
                       styleClass="content-subtitle"/>
            </placeholder>
        </TableView>

        <StackPane fx:id="loadingOverlay" visible="false"
                   style="-fx-background-color: rgba(0,0,0,0.35);">
            <ProgressIndicator fx:id="progressIndicator"/>
        </StackPane>
    </StackPane>
</VBox>
